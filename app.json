{
  "expo": {
    "name": "CarSpot",
    "slug": "carSpot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "carspot",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B11"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.carspot.app",
      "deploymentTarget": "18.0",
      "infoPlist": {
        "NSCameraUsageDescription": "CarSpot uses your camera to identify and capture cars.",
        "NSLocationWhenInUseUsageDescription": "CarSpot records where you spotted each car.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CarSpot records where you spotted each car."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080B11",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.carspot.app",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      ["expo-router", { "root": "src/app" }],
      [
        "expo-camera",
        {
          "cameraPermission": "CarSpot uses your camera to identify and capture cars."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CarSpot records where you spotted each car."
        }
      ],
      "expo-maps",
      "expo-audio",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.0",
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
